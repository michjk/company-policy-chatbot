# LLM Provider: openrouter | ollama | lmstudio
LLM_PROVIDER=openrouter

# OpenRouter (default provider)
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=anthropic/claude-sonnet-4-6

# Ollama (hosted locally — use host.docker.internal when running inside Docker)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_CHAT_MODEL=llama3.1

# LMStudio (local, OpenAI-compatible)
LMSTUDIO_BASE_URL=http://host.docker.internal:1234/v1
LMSTUDIO_MODEL=local-model
LMSTUDIO_API_KEY=lm-studio

# Embeddings (Ollama)
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIM=768

# Postgres + pgvector
POSTGRES_URL=postgresql://app:app@postgres:5432/policies
PGVECTOR_COLLECTION=company_policies

# Chunking
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
RETRIEVAL_K=4

# Observability — omit or leave blank to disable
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=company-policy-chatbot

OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=company-policy-chatbot
